# Copy to .env in this directory (supabase/.env is gitignored).
# Used by `supabase start` for local GoTrue — enables Google when vars are set.
#
# In Google Cloud Console → OAuth client → Authorized redirect URIs, add exactly:
#   http://127.0.0.1:54321/auth/v1/callback
# (Use the same Client ID / secret here.)

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
