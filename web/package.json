{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"---------------------- DEV WORKFLOW ----------------------": "",
		"generate_icon": "pwag static/icon.svg src/web-config.json && cp static/pwa/favicon-512.png static/maskable_icon_512x512.png",
		"generate-routes-manifest": "node ../scripts/generate-routes-manifest.mjs",
		"clean": "rm -rf node_modules && rm -f pnpm-lock.yaml && pnpm install",
		"clean:kit": "rm -rf .svelte-kit node_modules/.vite",
		"dev": "pnpm run generate_icon && NODE_ENV=development NODE_OPTIONS=--max-http-header-size=65536 vite dev",
		"dev:clean": "pnpm run clean:kit && pnpm run dev",
		"build": "vite build",
		"preview": "NODE_OPTIONS=--max-http-header-size=65536 vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"lint": "eslint ."
	},
	"dependencies": {
		"@shikijs/transformers": "^4.0.2",
		"@tanstack/svelte-form": "^1.28.4",
		"@tiptap/core": "^3.20.4",
		"@tiptap/extension-image": "^3.20.4",
		"@tiptap/extension-link": "^3.20.4",
		"@tiptap/extensions": "^3.20.4",
		"@tiptap/pm": "^3.20.4",
		"@tiptap/starter-kit": "^3.20.4",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"mdsvex": "^0.12.7",
		"shiki": "^4.0.2",
		"svelte-meta-tags": "^4.5.0",
		"svelte-motion": "^0.12.2",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-vercel": "^5.10.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"autoprefixer": "^10.4.27",
		"daisyui": "^5.5.19",
		"eslint": "^9.39.2",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"postcss": "^8.5.6",
		"pwag": "^0.4.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
